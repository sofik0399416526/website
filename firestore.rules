rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // Users collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.email.size() > 0;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);

      // Cart subcollection
      match /cart/{itemId} {
        function isValidCartItem(data) {
          return data.keys().hasAll(['productId', 'quantity', 'userId']) &&
                 data.userId == request.auth.uid &&
                 data.quantity is int && data.quantity > 0 &&
                 data.productId is int;
        }

        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidCartItem(request.resource.data);
        allow update: if isOwner(userId) && 
                        isValidCartItem(request.resource.data) &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
